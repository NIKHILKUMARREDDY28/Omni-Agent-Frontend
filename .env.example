# Copy this file to .env.local and fill in real values.
# .env.local is gitignored — never commit real secrets.

# Leave EMPTY. The app then uses same-origin relative paths (/api, /health),
# which are forwarded by the server-side proxy (Vercel Edge Function in prod,
# Vite dev proxy locally). This avoids CORS and keeps the CF secret off the
# browser. Only set this if you intend to call a backend directly (not advised
# for CF-Access-protected backends).
VITE_API_BASE_URL=https://omni-agent.nuark.ai

# ── Server-only (NOT exposed to the browser — no VITE_ prefix) ──────────
# Where the proxy forwards /api and /health. Used by the Vite dev proxy and,
# on Vercel, by the Edge Function (set the same vars in Project Settings).
BACKEND_URL=https://omni-agent.nuark.ai
# API_PROXY_TARGET is an accepted alias for BACKEND_URL in the dev proxy.
API_PROXY_TARGET=https://omni-agent.nuark.ai

# Cloudflare Access service token (Zero Trust > Access > Service Auth).
# Injected server-side by the proxy. Both must be set to send the headers.
CF_ACCESS_CLIENT_ID=your-client-id.access
CF_ACCESS_CLIENT_SECRET=your-client-secret